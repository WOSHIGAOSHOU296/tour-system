<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
         version="3.1">

    <display-name>个性化旅游定制平台</display-name>

    <!-- 欢迎页面 -->
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <!-- Session 配置 -->
    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>

    <!-- ==================== Servlet 映射 ==================== -->
    <servlet>
        <servlet-name>UserController</servlet-name>
        <servlet-class>com.tour.controller.UserController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>UserController</servlet-name>
        <url-pattern>/user</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ScenicController</servlet-name>
        <servlet-class>com.tour.controller.ScenicController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ScenicController</servlet-name>
        <url-pattern>/scenic</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ForumController</servlet-name>
        <servlet-class>com.tour.controller.ForumController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ForumController</servlet-name>
        <url-pattern>/forum</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>StrategyController</servlet-name>
        <servlet-class>com.tour.controller.StrategyController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>StrategyController</servlet-name>
        <url-pattern>/strategy</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>TripController</servlet-name>
        <servlet-class>com.tour.controller.TripController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>TripController</servlet-name>
        <url-pattern>/trip</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AdminController</servlet-name>
        <servlet-class>com.tour.controller.AdminController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminController</servlet-name>
        <url-pattern>/admin</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>CollectionController</servlet-name>
        <servlet-class>com.tour.controller.CollectionController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CollectionController</servlet-name>
        <url-pattern>/collection</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ScenicAdminController</servlet-name>
        <servlet-class>com.tour.controller.ScenicAdminController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ScenicAdminController</servlet-name>
        <url-pattern>/scenicAdmin</url-pattern>
    </servlet-mapping>

    <!-- ==================== Filter 映射 ==================== -->
    <!-- 景区管理员权限过滤器（roleId=3） -->
    <filter>
        <filter-name>ScenicAdminFilter</filter-name>
        <filter-class>com.tour.filter.ScenicAdminFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>ScenicAdminFilter</filter-name>
        <url-pattern>/scenicAdmin</url-pattern>
        <url-pattern>/scenicAdmin/*</url-pattern>
    </filter-mapping>
    <filter>
        <filter-name>LoginFilter</filter-name>
        <filter-class>com.tour.filter.LoginFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>LoginFilter</filter-name>
        <url-pattern>/forum</url-pattern>
        <url-pattern>/forum/*</url-pattern>
        <url-pattern>/trip</url-pattern>
        <url-pattern>/trip/*</url-pattern>
        <url-pattern>/strategy</url-pattern>
        <url-pattern>/strategy/*</url-pattern>
        <url-pattern>/collection</url-pattern>
        <url-pattern>/collection/*</url-pattern>
        <url-pattern>/scenicAdmin</url-pattern>
        <url-pattern>/scenicAdmin/*</url-pattern>
        <url-pattern>/admin</url-pattern>
        <url-pattern>/admin/*</url-pattern>
    </filter-mapping>

    <filter>
        <filter-name>AdminFilter</filter-name>
        <filter-class>com.tour.filter.AdminFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>AdminFilter</filter-name>
        <url-pattern>/admin/*</url-pattern>
    </filter-mapping>

</web-app>
